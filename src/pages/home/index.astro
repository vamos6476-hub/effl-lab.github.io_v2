---
import Hero from "@/components/blocks/Hero.astro";
import NewsTimeline from "@/components/blocks/NewsTimeline.astro";
import EditPageLink from "@/components/layout/EditPageLink.astro";
import Layout from "@/layouts/Layout.astro";
import site from "@/config/site";
import { Icon } from "astro-icon/components";
import type { NewsEntry } from "./news/_types.mts";

const mainNewsModules = import.meta.glob<{ default?: NewsEntry[] }>(
  "./news/main/*.mts",
  { eager: true },
);
const moreNewsModules = import.meta.glob<{ default?: NewsEntry[] }>(
  "./news/more/*.mts",
  { eager: true },
);

function collectNewsEntries(
  modules: Record<string, { default?: NewsEntry[] }>,
) {
  return Object.entries(modules)
    .filter(([path, module]) => {
      if (path.endsWith("/example.mts")) {
        return false;
      }

      return Array.isArray(module.default);
    })
    .sort(([pathA], [pathB]) => pathA.localeCompare(pathB))
    .flatMap(([, module]) => module.default ?? []);
}

const mainNews = collectNewsEntries(mainNewsModules);
const moreNews = collectNewsEntries(moreNewsModules);
---

<Layout title={site.meta.title} description={site.meta.description}>
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-4xl p-8 duration-700 md:p-16"
  >
    <Hero />

    <section class="space-y-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h3 class="text-xl font-bold tracking-tight">News</h3>
        </div>
      </div>

      <NewsTimeline items={mainNews} />

      {
        moreNews.length > 0 && (
          <section class="space-y-3">
            <button
              type="button"
              data-news-toggle
              aria-expanded="false"
              class="inline-flex items-center gap-2 text-sm font-semibold text-muted-foreground transition-colors hover:text-primary"
            >
              <Icon
                name="mdi:play"
                data-news-toggle-icon
                class="h-3.5 w-3.5 shrink-0 rotate-90 transition-transform duration-300"
              />
              <span>More</span>
            </button>

            <div data-news-panel data-expanded="false" class="news-panel">
              <div class="news-panel-inner pt-4">
                <NewsTimeline items={moreNews} />

                <div class="mt-5">
                  <a
                    href="/home/news"
                    class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-primary"
                  >
                    <span>Past News</span>
                    <Icon name="mdi:arrow-right" class="h-4 w-4" />
                  </a>
                </div>
              </div>
            </div>
          </section>
        )
      }
    </section>

    <EditPageLink />
  </div>
</Layout>

<style>
  .news-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(-0.45rem);
    transition:
      grid-template-rows 420ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 260ms ease,
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .news-panel[data-expanded="true"] {
    grid-template-rows: 1fr;
    opacity: 1;
    transform: translateY(0);
  }

  .news-panel-inner {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .news-panel {
      transition: none;
    }
  }
</style>

<script is:inline>
  if (!window.__efflNewsToggleBound) {
    window.__efflNewsToggleBound = true;

    document.addEventListener("click", (event) => {
      const button = event.target.closest("[data-news-toggle]");
      if (!(button instanceof HTMLButtonElement)) return;

      const panel = button.parentElement?.querySelector("[data-news-panel]");
      const icon = button.querySelector("[data-news-toggle-icon]");
      if (!(panel instanceof HTMLElement)) return;

      const isExpanded = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!isExpanded));
      panel.dataset.expanded = String(!isExpanded);

      if (icon instanceof HTMLElement) {
        icon.style.transform = isExpanded ? "rotate(90deg)" : "rotate(180deg)";
      }
    });
  }
</script>
