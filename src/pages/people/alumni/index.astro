---
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import EditPageLink from "@/components/layout/EditPageLink.astro";
import { Icon } from "astro-icon/components";
import type { AlumniEntry } from "./_types.mts";

// Add person files in `src/pages/people/alumni/*.mts`.
// Each file should export a default `AlumniEntry`.
const alumniModules = import.meta.glob<{ default?: AlumniEntry }>("./*.mts", {
  eager: true,
});

const alumni = Object.values(alumniModules)
  .flatMap((module, index) => {
    const path = Object.keys(alumniModules)[index] ?? "";

    if (path.endsWith("/example.mts")) {
      return [];
    }

    return module.default ? [module.default] : [];
  })
  .sort(
    (a, b) =>
      (a.order ?? Number.MAX_SAFE_INTEGER) -
        (b.order ?? Number.MAX_SAFE_INTEGER) || a.name.localeCompare(b.name),
  );

function getInitials(name: string) {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("");
}

function getLinkIcon(label: string, href: string) {
  const normalizedLabel = label.toLowerCase();
  const normalizedHref = href.toLowerCase();

  if (
    normalizedLabel.includes("mail") ||
    normalizedHref.startsWith("mailto:")
  ) {
    return "mdi:email-outline";
  }
  if (normalizedLabel.includes("linkedin")) return "mdi:linkedin";
  if (normalizedLabel === "x") return "mdi:alpha-x-box-outline";
  if (normalizedLabel.includes("twitter")) return "mdi:twitter";
  if (normalizedLabel.includes("blog")) return "mdi:notebook-outline";
  if (normalizedLabel.includes("project")) return "mdi:rocket-launch-outline";
  if (normalizedLabel.includes("webpage")) return "mdi:web";

  return "mdi:link-variant";
}
---

<Layout title="Alumni" description="Former members of EffL.">
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-4xl p-8 duration-700 md:p-16"
  >
    <header class="mb-12">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Alumni</h2>
      <p class="text-sm font-light text-muted-foreground italic"></p>
    </header>

    <div class="space-y-5">
      {
        alumni.map((person) => (
          <article class="group rounded-[1.8rem] border border-border/60 bg-muted/15 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:bg-muted/35 hover:shadow-lg">
            <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
              {person.avatar ? (
                <div class="relative h-20 w-20 shrink-0 overflow-hidden rounded-2xl border border-primary/15 bg-primary/10">
                  <Image
                    src={person.avatar}
                    alt={`${person.name}'s photo`}
                    width={249}
                    height={320}
                    fit="cover"
                    class="absolute inset-0 h-full w-full object-cover"
                  />
                </div>
              ) : (
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl border border-primary/15 bg-primary/10 text-base font-bold text-primary">
                  {getInitials(person.name)}
                </div>
              )}

              <div class="min-w-0 flex-1">
                <h3 class="text-lg font-bold tracking-tight text-foreground">
                  {person.name}
                </h3>

                <p class="mt-2 text-sm leading-relaxed text-foreground/85">
                  {person.summary}
                </p>

                <div class="mt-4 space-y-2 text-sm leading-relaxed">
                  <p class="text-muted-foreground">
                    <span class="font-semibold text-foreground">
                      Expertise.
                    </span>{" "}
                    {person.expertise}
                  </p>
                  <p class="text-muted-foreground">
                    <span class="font-semibold text-foreground">
                      Next step.
                    </span>{" "}
                    {person.nextStep}
                  </p>
                </div>

                <div class="mt-5 flex flex-wrap gap-2">
                  {person.links.map((link) => (
                    <a
                      href={link.href}
                      aria-label={link.label}
                      title={link.label}
                      target={
                        link.href.startsWith("mailto:") ? undefined : "_blank"
                      }
                      rel={
                        link.href.startsWith("mailto:")
                          ? undefined
                          : "noopener noreferrer"
                      }
                      class="flex h-9 w-9 items-center justify-center rounded-lg border border-border/55 bg-background/70 text-foreground/75 transition-colors hover:border-primary/35 hover:text-primary"
                    >
                      <Icon
                        name={getLinkIcon(link.label, link.href)}
                        class="h-4 w-4 shrink-0"
                      />
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-10">
      <a
        href="/people"
        class="text-sm font-medium text-primary hover:underline"
      >
        Back to People
      </a>
    </div>

    <EditPageLink />
  </div>
</Layout>
