---
import Layout from "@/layouts/Layout.astro";
import EditPageLink from "@/components/layout/EditPageLink.astro";
import type { JoinUsEntry } from "./_types.mts";
import { getJoinUsContent, getJoinUsItems } from "./_data.mts";

interface Props {
  item: JoinUsEntry;
  Content: unknown;
}

export function getStaticPaths() {
  return getJoinUsItems().map((item) => {
    const Content = getJoinUsContent(item.slug);

    if (!Content) {
      throw new Error(
        `Missing join-us content file for slug "${item.slug}". Add src/pages/join-us/${item.slug}/content.md.`,
      );
    }

    return {
      params: { slug: item.slug },
      props: {
        item,
        Content,
      },
    };
  });
}

const { item, Content } = Astro.props as Props;
const pageDescription = "How to join EffL.";
---

<Layout title={item.title} description={pageDescription}>
  <div class="animate-in fade-in mx-auto max-w-3xl p-8 duration-700 md:p-16">
    <header class="mb-10">
      <h2 class="text-3xl font-bold tracking-tight">{item.title}</h2>
    </header>

    <div class="prose dark:prose-invert">
      <Content />
    </div>

    <div class="mt-10">
      <a
        href="/join-us"
        class="text-sm font-medium text-primary hover:underline"
      >
        Back to Join Us
      </a>
    </div>

    <EditPageLink />
  </div>
</Layout>
