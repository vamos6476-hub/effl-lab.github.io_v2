---
import Layout from "@/layouts/Layout.astro";
import EditPageLink from "@/components/layout/EditPageLink.astro";

interface MarkdownModule {
  default: unknown;
}

const researchModules = import.meta.glob<MarkdownModule>("./*.md", {
  eager: true,
});

const researchSections = Object.entries(researchModules)
  .filter(([path]) => !path.endsWith("/example.md"))
  .sort(([pathA], [pathB]) => pathA.localeCompare(pathB))
  .map(([, module]) => module.default);
---

<Layout title="Research" description="Research directions and focus areas">
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-5xl p-8 duration-700 md:p-16"
  >
    <div
      class="relative overflow-hidden rounded-[2rem] border border-border/70 bg-card/95 px-6 py-8 md:px-10 md:py-10"
    >
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(16,185,129,0.08),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.02),transparent)] opacity-90"
      >
      </div>
      <div class="relative prose max-w-none">
        {researchSections.map((Section) => <Section />)}
      </div>
    </div>

    <EditPageLink />
  </div>
</Layout>
