---
import site from "@/config/site";
import Nav from "./Nav.astro";
import { Icon } from "astro-icon/components";
import Brand from "./Brand.astro";
---

<aside
  class="flex w-full flex-col border-b border-border bg-muted/20 p-5 md:w-[29%] md:border-r md:border-b-0 md:p-8 lg:w-[27%] lg:p-9"
  data-pagefind-ignore="all"
>
  <Brand />

  <Nav />

  <div class="mt-6 flex items-center md:mt-10">
    <div class="flex gap-4 text-muted-foreground/60">
      {
        site.social.map((item) => (
          <a
            href={item.href}
            class="cursor-pointer transition-colors hover:text-primary"
            aria-label={item.name}
          >
            <Icon name={item.icon} size={24} />
          </a>
        ))
      }
    </div>
  </div>
</aside>
