---
import site from "@/config/site";
import type { HeadProps } from "@/types";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

type Props = HeadProps;

const { title, description, image = site.ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!-- Global Metadata -->
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/postech_logo.png?v=20260401" />

  <!-- Apple Touch Icon -->
  <link rel="apple-touch-icon" href="/effl_logo.png?v=20260401" />

  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json" />

  <!-- Theme Color -->
  <meta name="theme-color" content="#3F9C87" />
  <meta name="msapplication-TileColor" content="#3F9C87" />

  <meta name="generator" content={Astro.generator} />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.url)} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta name="twitter:creator" content={`@${site.meta.author}`} />
  <meta name="twitter:image" content={new URL(image, Astro.url)} />

  <!-- canonical url -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- font  -->
  <Font cssVariable="--font-display" preload />

  <!-- View Transtions -->
  <ClientRouter />
</head>
