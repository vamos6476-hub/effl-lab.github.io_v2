---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Avatar from "@/components/bearnie/avatar/Avatar.astro";
import AvatarImage from "@/components/bearnie/avatar/AvatarImage.astro";
import AvatarFallback from "@/components/bearnie/avatar/AvatarFallback.astro";
import type { PersonEntry } from "@/pages/people/members/_types.mts";

interface Props {
  person: PersonEntry;
}

const { person } = Astro.props;
const avatarAlt = `${person.name}'s photo`;
const tags = person.tags ?? [];
const links = person.links ?? [];

function getInitials(name: string) {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("");
}
---

<div
  class="group flex h-full flex-col rounded-2xl border border-border/50 bg-muted/20 p-5 transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:bg-muted/40 hover:shadow-lg"
>
  <div class="mb-4 flex items-start justify-between gap-3">
    <Avatar
      size="lg"
      class="bg-primary/10 text-primary ring-1 ring-primary/15 transition-all duration-300 group-hover:ring-primary/25"
    >
      {
        person.avatar &&
          (typeof person.avatar === "string" ? (
            <AvatarImage src={person.avatar} alt={avatarAlt} />
          ) : (
            <Image
              src={person.avatar}
              alt={avatarAlt}
              width={249}
              height={320}
              fit="cover"
              class="absolute inset-0 z-10 h-full w-full object-cover"
            />
          ))
      }
      <AvatarFallback class="bg-primary/10 font-semibold text-primary">
        {getInitials(person.name)}
      </AvatarFallback>
    </Avatar>

    {
      person.status && (
        <span class="rounded-full border border-primary/20 bg-primary/10 px-2 py-0.5 text-[9px] font-bold tracking-widest text-primary uppercase">
          {person.status}
        </span>
      )
    }
  </div>

  <h3 class="mb-1 text-base font-bold">{person.name}</h3>

  {
    person.role && (
      <p class="mb-3 text-xs font-medium tracking-wide text-primary/80">
        {person.role}
      </p>
    )
  }

  <p class="mb-4 flex-1 text-xs leading-relaxed text-muted-foreground">
    {person.bio}
  </p>

  {
    tags.length > 0 && (
      <div class="mb-3 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="font-mono text-[10px] text-primary/50">#{tag}</span>
        ))}
      </div>
    )
  }

  {
    links.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.label}
            title={link.label}
            class="flex h-9 w-9 items-center justify-center rounded-lg border border-border/50 bg-muted/30 text-foreground/70 hover:border-primary/40 hover:text-primary"
          >
            <Icon name={link.icon} class="h-4 w-4" />
          </a>
        ))}
      </div>
    )
  }
</div>
